rules_version = '2';

// Nabdh Firestore security rules.
// Health data is sensitive (PDPL): every document is scoped to its owner and
// access requires an authenticated user reading/writing only their own data.
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Per-user root document and all of its subcollections
    // (profile, healthDaily, meals, coachMemory, consents, insights, subscriptions).
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /{document=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
