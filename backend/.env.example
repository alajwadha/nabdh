# Nabdh backend environment (copy to .env; never commit .env)
PORT=8080

# Google Cloud / Vertex AI (Phase 3) - managed default model, in-region
GOOGLE_CLOUD_PROJECT=
VERTEX_LOCATION=me-central1
VERTEX_DEFAULT_MODEL=gemini-2.5-flash

# Google Health API OAuth (Phase 2) - SERVER-SIDE ONLY, never ship to the app
GOOGLE_HEALTH_CLIENT_ID=
GOOGLE_HEALTH_CLIENT_SECRET=
GOOGLE_HEALTH_REDIRECT_URI=

# Nutrition data (Phase 4)
FATSECRET_CLIENT_ID=
FATSECRET_CLIENT_SECRET=
USDA_FDC_API_KEY=
