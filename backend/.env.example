# Nabdh backend environment (copy to .env; never commit .env)
PORT=8080

# AI coach provider: 'vertex' (in-region Gemini, default) or 'groq' (US, testing)
AI_PROVIDER=vertex

# Google Cloud / Vertex AI (Phase 3) - managed default model, in-region
GOOGLE_CLOUD_PROJECT=
VERTEX_LOCATION=me-central1
VERTEX_DEFAULT_MODEL=gemini-2.5-flash

# Groq (optional alternative for quick testing) - SERVER-SIDE ONLY, never in the app
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# BYO "Pro" providers (US-hosted, cross-border, opt-in). SERVER-SIDE ONLY.
# Select with AI_PROVIDER=anthropic | openai | gemini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Google Health API OAuth (Phase 2) - SERVER-SIDE ONLY, never ship to the app
GOOGLE_HEALTH_CLIENT_ID=
GOOGLE_HEALTH_CLIENT_SECRET=
GOOGLE_HEALTH_REDIRECT_URI=

# Nutrition data (Phase 4)
FATSECRET_CLIENT_ID=
FATSECRET_CLIENT_SECRET=
USDA_FDC_API_KEY=
