{
  "expo": {
    "name": "Nabdh",
    "slug": "nabdh",
    "scheme": "nabdh",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "backgroundColor": "#0B0F14",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.nabdh.app",
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.nabdh.app"
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      "expo-secure-store",
      "expo-apple-authentication",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Nabdh uses your location to calculate accurate prayer times for where you are and to map your outdoor workouts. Your location stays on your device."
        }
      ],
      [
        "@kingstinct/react-native-healthkit",
        {
          "NSHealthShareUsageDescription": "Nabdh reads your steps, heart rate, sleep, and energy from Apple Health to show your dashboard and personalize coaching. Your health data stays on your device unless you explicitly consent to AI coaching.",
          "NSHealthUpdateUsageDescription": "Nabdh can write workouts and nutrition you log back to Apple Health.",
          "background": true
        }
      ],
      "expo-web-browser",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "firebase": {
        "apiKey": "AIzaSyCJxDJ6map8GgXEQjJeeHMQP1nYFlUugt8",
        "authDomain": "nabdh-44915.firebaseapp.com",
        "projectId": "nabdh-44915",
        "storageBucket": "nabdh-44915.firebasestorage.app",
        "messagingSenderId": "517247723861",
        "appId": "1:517247723861:web:6f8422e08fbeb5d44d67dc"
      },
      "google": {
        "iosClientId": "",
        "androidClientId": "",
        "webClientId": ""
      },
      "fitbit": {
        "clientId": ""
      },
      "googleHealth": {
        "clientId": ""
      },
      "backendUrl": "",
      "router": {},
      "eas": {
        "projectId": "c5050164-fe37-41c7-95e2-672d149b8d26"
      }
    },
    "owner": "alajwadha"
  }
}
